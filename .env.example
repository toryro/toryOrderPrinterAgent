# toryOrder 프린터 에이전트 설정
# 이 파일을 복사해 .env 로 저장하고 값을 채워주세요.

# 백엔드 서버 주소
SERVER_URL=http://localhost:8000

# 매장 ID (관리자 페이지 URL의 숫자)
STORE_ID=1

# 매장 계정 (STORE_OWNER 권한 필요)
EMAIL=owner@example.com
PASSWORD=yourpassword

# ── 프린터 연결 방식 ──────────────────────────────────────
# PRINTER_TYPE: NETWORK | SERIAL | FILE | (빈칸 = 콘솔 출력 모드)
#
# [NETWORK] LAN / Wi-Fi 열화지 프린터 (가장 일반적)
#   PRINTER_TYPE=NETWORK
#   PRINTER_HOST=192.168.0.100   ← 프린터 IP
#   PRINTER_PORT=9100            ← 보통 9100 고정
#
# [SERIAL] USB 시리얼 열화지 프린터
#   PRINTER_TYPE=SERIAL
#   PRINTER_PORT=COM3            ← Windows: COM3 / Linux·Mac: /dev/usb/lp0
#   PRINTER_BAUD=9600
#
# [FILE] 파일 경로로 직접 쓰기 (Linux USB 직접 연결)
#   PRINTER_TYPE=FILE
#   PRINTER_PORT=/dev/usb/lp0

PRINTER_TYPE=
PRINTER_HOST=
PRINTER_PORT=9100
PRINTER_BAUD=9600
